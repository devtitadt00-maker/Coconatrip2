/**
 * @file GalleryGrid.tsx
 * @description Grid gallery dan lightbox modal sederhana untuk melihat gambar lebih besar.
 */

import React, { useState } from "react";
import GalleryItem from "./GalleryItem";
import { X, ChevronLeft, ChevronRight } from "lucide-react";

/**
 * @interface GalleryImage
 * @description Struktur data satu entri gambar di gallery
 */
export interface GalleryImage {
  src: string;
  alt?: string;
  caption?: string;
}

/**
 * @interface GalleryGridProps
 * @description Props untuk GalleryGrid — menerima array gambar
 */
export interface GalleryGridProps {
  images: GalleryImage[];
}

/**
 * @component GalleryGrid
 * @description Menampilkan grid thumbnail dan mengelola lightbox modal (open/close, prev/next).
 */
export default function GalleryGrid({ images }: GalleryGridProps) {
  const [index, setIndex] = useState<number | null>(null);

  /**
   * @description Buka modal pada index tertentu
   * @param i index gambar
   */
  function openAt(i: number) {
    setIndex(i);
  }

  /**
   * @description Tutup modal
   */
  function close() {
    setIndex(null);
  }

  /**
   * @description Pindah ke gambar sebelumnya di modal
   */
  function prev() {
    if (index === null) return;
    setIndex((index - 1 + images.length) % images.length);
  }

  /**
   * @description Pindah ke gambar berikutnya di modal
   */
  function next() {
    if (index === null) return;
    setIndex((index + 1) % images.length);
  }

  return (
    <div>
      <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {images.map((img, i) => (
          <GalleryItem key={i} src={img.src} alt={img.alt} caption={img.caption} onOpen={() => openAt(i)} />
        ))}
      </div>

      {index !== null && (
        <div
          role="dialog"
          aria-modal="true"
          className="fixed inset-0 z-50 flex items-center justify-center p-6"
        >
          <div
            className="absolute inset-0 bg-black/70 backdrop-blur-sm"
            onClick={close}
          />
          <div className="relative max-w-4xl w-full mx-auto">
            <button
              onClick={close}
              className="absolute right-2 top-2 z-20 inline-flex items-center justify-center rounded-md bg-white/90 text-gray-800 hover:bg-white p-2 shadow"
              aria-label="Close"
            >
              <X size={18} />
            </button>

            <div className="flex items-center">
              <button
                onClick={prev}
                aria-label="Previous image"
                className="mr-2 hidden sm:inline-flex items-center justify-center rounded-full bg-white/90 p-2 shadow"
              >
                <ChevronLeft />
              </button>

              <div className="bg-white/90 rounded-md overflow-hidden shadow-lg">
                <img src={images[index].src} alt={images[index].alt ?? images[index].caption ?? "Image"} className="w-full h-[60vh] object-contain bg-black" />
                {images[index].caption ? (
                  <div className="p-3 text-sm text-gray-800 bg-white">
                    {images[index].caption}
                  </div>
                ) : null}
              </div>

              <button
                onClick={next}
                aria-label="Next image"
                className="ml-2 hidden sm:inline-flex items-center justify-center rounded-full bg-white/90 p-2 shadow"
              >
                <ChevronRight />
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
